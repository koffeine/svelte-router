{
	"exclude": [
		"dist"
	],
	"compilerOptions": {
		// Type Checking
		"strict": true,

		// Modules
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"noUncheckedSideEffectImports": true,
		"types": [],

		// Emit
		"noEmit": true,

		// JavaScript Support
		"allowJs": true,
		"checkJs": true,

		// Editor Support
		"plugins": [ { "name": "typescript-svelte-plugin" } ],

		// Language and Environment
		"target": "esnext",

		// Completeness
		"skipLibCheck": true
	}
}
