{
  "name": "@koffeine/svelte-router",
  "version": "4.0.4",
  "description": "Router for Svelte",
  "keywords": [
    "svelte",
    "router"
  ],
  "homepage": "https://github.com/koffeine/svelte-router",
  "bugs": {
    "url": "https://github.com/koffeine/svelte-router/issues"
  },
  "license": "MIT",
  "author": "Kornél Horváth <kornel.horvath@me.com>",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koffeine/svelte-router.git"
  },
  "scripts": {
    "test": "eslint && svelte-check --tsconfig jsconfig.json && vitest run",
    "build": "vite build && esbuild --minify <dist/svelte-router.js >index.js && rm -rf dist",
    "prepublishOnly": "npm test && npm run build",
    "postpublish": "rm index.js"
  },
  "dependencies": {
    "regexparam": "^3"
  },
  "devDependencies": {
    "@koffeine/eslint-config": "41.0.0",
    "@sveltejs/vite-plugin-svelte": "^5",
    "@types/chai": "^5",
    "@types/jsdom-global": "^3",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "esbuild": "^0",
    "eslint": "9.26.0",
    "eslint-plugin-svelte": "^3",
    "globals": "^16",
    "jsdom-global": "^3",
    "svelte": "^5",
    "svelte-check": "^4",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^3"
  },
  "peerDependencies": {
    "svelte": "^5"
  }
}
